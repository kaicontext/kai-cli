package views

import "testing"

func TestLooksLikeActionOffer(t *testing.T) {
	offers := []string{
		"I found the bug in the parser. Want me to apply the fix?",
		"That test is stale. Shall I update it?",
		"Should I go ahead and rename the field everywhere?",
		"There are three callers. Do you want me to patch them all?",
		"Looks straightforward — like me to make the change?",
	}
	for _, s := range offers {
		if !looksLikeActionOffer(s) {
			t.Errorf("expected action offer, got false: %q", s)
		}
	}

	notOffers := []string{
		"Here's how the parser works.",
		"The bug is on line 42.",
		"Let me know which file to look at.",
		"I already applied the fix.",
		"Why does this happen? Because the cache is cold.",
	}
	for _, s := range notOffers {
		if looksLikeActionOffer(s) {
			t.Errorf("expected no action offer, got true: %q", s)
		}
	}
}
